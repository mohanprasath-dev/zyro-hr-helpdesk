E_CSV = \"/kaggle/input/competitions/niat-masterclass-rag-challenge/sample_submission.xlsx\"\n\n# ── Chunking ────────────────────────────────────────────────────────────────\nCHUNK_SIZE    = 800    # characters per chunk\nCHUNK_OVERLAP = 150   # overlap to preserve context across chunk boundaries\n\n# ── Retrieval ───────────────────────────────────────────────────────────────\nTOP_K         = 5     # number of chunks to retrieve\nMMR_LAMBDA    = 0.6   # diversity vs relevance balance (0=diverse, 1=relevant)\n\n# ── Embedding model (free, runs locally on Kaggle) ──────────────────────────\nEMBED_MODEL   = \"sentence-transformers/all-MiniLM-L6-v2\"\n\n# ── LLM ────────────────────────────────────────────────────────────────────\nLLM_MODEL = \"llama-3.3-70b-versatile\"   # Groq: fast, free, high quality\n\nprint(\"✅ Configuration set\")\nprint(f\"   PDF directory : {PDF_DIR}\")\nprint(f\"   Chunk size    : {CHUNK_SIZE} chars (overlap: {CHUNK_OVERLAP})\")\nprint(f\"   Retrieval     : Top-{TOP_K} with MMR (λ={MMR_LAMBDA})\")\nprint(f\"   Embeddings    : {EMBED_MODEL}\")\nprint(f\"   LLM           : {LLM_MODEL} via Groq\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:38.952658Z","iopub.execute_input":"2026-06-24T13:02:38.952946Z","iopub.status.idle":"2026-06-24T13:02:38.958711Z","shell.execute_reply.started":"2026-06-24T13:02:38.952925Z","shell.execute_reply":"2026-06-24T13:02:38.95808Z"}},"outputs":[{"name":"stdout","text":"✅ Configuration set\n   PDF directory : /kaggle/input/competitions/niat-masterclass-rag-challenge/zyro-dynamics-hr-corpus\n   Chunk size    : 800 chars (overlap: 150)\n   Retrieval     : Top-5 with MMR (λ=0.6)\n   Embeddings    : sentence-transformers/all-MiniLM-L6-v2\n   LLM           : llama-3.3-70b-versatile via Groq\n","output_type":"stream"}],"execution_count":57},{"id":"b81fcacc-2504-45f6-8c7b-ba36b1d21728","cell_type":"markdown","source":"## Cell 5 — ✅ TODO 1: Load HR PDFs","metadata":{}},{"id":"1d961174-490f-4b74-ae66-0088b455e2af","cell_type":"code","source":"# ── TODO 1: Load all 11 HR PDF documents ───────────────────────────────────\n#\n# We use PyPDFLoader which extracts text page-by-page.\n# Each page becomes a separate Document object with metadata\n# (source filename + page number) — crucial for source citations later.\n\ndef load_hr_pdfs(pdf_dir: str) -> list:\n    \"\"\"Load all PDF files from the given directory.\n    Returns a flat list of LangChain Document objects.\"\"\"\n    all_docs = []\n    pdf_paths = sorted(glob.glob(os.path.join(pdf_dir, \"*.pdf\")))\n\n    if not pdf_paths:\n        raise FileNotFoundError(f\"No PDF files found in {pdf_dir}\")\n\n    for pdf_path in pdf_paths:\n        loader = PyPDFLoader(pdf_path)\n        pages  = loader.load()          # returns list[Document], one per page\n\n        # Enrich metadata so we can show source citations in the chatbot\n        filename = Path(pdf_path).stem\n        for doc in pages:\n            doc.metadata[\"source\"]   = filename\n            doc.metadata[\"filepath\"] = pdf_path\n\n        all_docs.extend(pages)\n        print(f\"   📄 {filename:<50} → {len(pages):>2} page(s)\")\n\n    return all_docs\n\n\nprint(\"Loading HR policy documents...\")\nraw_documents = load_hr_pdfs(PDF_DIR)\n\nprint(f\"\\n✅ Loaded {len(raw_documents)} pages from {len(glob.glob(PDF_DIR + '*.pdf'))} PDF files\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:38.959861Z","iopub.execute_input":"2026-06-24T13:02:38.960143Z","iopub.status.idle":"2026-06-24T13:02:39.700808Z","shell.execute_reply.started":"2026-06-24T13:02:38.960122Z","shell.execute_reply":"2026-06-24T13:02:39.700242Z"}},"outputs":[{"name":"stdout","text":"Loading HR policy documents...\n   📄 00_Company_Profile                                 →  4 page(s)\n   📄 01_Employee_Handbook                               →  4 page(s)\n   📄 02_Leave_Policy                                    →  4 page(s)\n   📄 03_Work_From_Home_Policy                           →  3 page(s)\n   📄 04_Code_of_Conduct                                 →  3 page(s)\n   📄 05_Performance_Review_Policy                       →  4 page(s)\n   📄 06_Compensation_and_Benefits_Policy                →  4 page(s)\n   📄 07_IT_and_Data_Security_Policy                     →  3 page(s)\n   📄 08_Prevention_of_Sexual_Harassment_Policy          →  3 page(s)\n   📄 09_Onboarding_and_Separation_Policy                →  4 page(s)\n   📄 10_Travel_and_Expense_Policy                       →  3 page(s)\n\n✅ Loaded 39 pages from 0 PDF files\n","output_type":"stream"}],"execution_count":58},{"id":"0f859ea6-9d1a-4a73-b796-514c59f76c9b","cell_type":"markdown","source":"## Cell 6 — ✅ TODO 2: Chunk the Documents","metadata":{}},{"id":"093d63d6-d9a0-438d-b9b3-fbf221998640","cell_type":"code","source":"# ── TODO 2: Split documents into overlapping chunks ─────────────────────────\n#\n# Why chunk?\n#   • Vector search works best on focused, short passages (~500-1000 chars)\n#   • Long pages dilute the embedding signal\n#\n# Why RecursiveCharacterTextSplitter?\n#   • Tries to split on \\n\\n → \\n → space → character (in that order)\n#   • Preserves paragraph/sentence boundaries when possible\n#\n# Why overlap?\n#   • Answers that span chunk boundaries are still retrievable\n\ndef chunk_documents(documents: list, chunk_size: int, chunk_overlap: int) -> list:\n    \"\"\"Split raw documents into smaller, overlapping text chunks.\"\"\"\n    splitter = RecursiveCharacterTextSplitter(\n        chunk_size=chunk_size,\n        chunk_overlap=chunk_overlap,\n        separators=[\"\\n\\n\", \"\\n\", \". \", \" \", \"\"],  # natural break points\n        length_function=len,\n    )\n    chunks = splitter.split_documents(documents)\n    return chunks\n\n\nprint(f\"Chunking {len(raw_documents)} pages (chunk={CHUNK_SIZE}, overlap={CHUNK_OVERLAP})...\")\nchunks = chunk_documents(raw_documents, CHUNK_SIZE, CHUNK_OVERLAP)\n\n# Quick stats\navg_len = sum(len(c.page_content) for c in chunks) / len(chunks)\nprint(f\"\\n✅ Created {len(chunks)} chunks\")\nprint(f\"   Average chunk length : {avg_len:.0f} characters\")\nprint(f\"\\n📋 Sample chunk [0]:\")\nprint(f\"   Source  : {chunks[0].metadata.get('source', 'N/A')}\")\nprint(f\"   Page    : {chunks[0].metadata.get('page', 'N/A')}\")\nprint(f\"   Content : {chunks[0].page_content[:200]}...\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:39.701787Z","iopub.execute_input":"2026-06-24T13:02:39.702086Z","iopub.status.idle":"2026-06-24T13:02:39.713648Z","shell.execute_reply.started":"2026-06-24T13:02:39.702055Z","shell.execute_reply":"2026-06-24T13:02:39.713055Z"}},"outputs":[{"name":"stdout","text":"Chunking 39 pages (chunk=800, overlap=150)...\n\n✅ Created 112 chunks\n   Average chunk length : 657 characters\n\n📋 Sample chunk [0]:\n   Source  : 00_Company_Profile\n   Page    : 0\n   Content : Zyro Dynamics Pvt. Ltd.\nCompany Profile\nDoc Code: ZDL-CORP-001\nConfidential — For Internal Use Only\nPage 1\n Zyro Dynamics Pvt. Ltd.\n \n Navigate the Future\n Company Profile\n Document Code\n ZDL-CORP-001...\n","output_type":"stream"}],"execution_count":59},{"id":"49bd859b-608f-4c74-9501-a7902b07e7c5","cell_type":"markdown","source":"## Cell 7 — ✅ TODO 3: Build FAISS Vector Store","metadata":{}},{"id":"6ef621a1-a9ed-4c37-a283-4bf84b8e829f","cell_type":"code","source":"# ── TODO 3: Embed chunks and build FAISS index ──────────────────────────────\n#\n# Embedding model: all-MiniLM-L6-v2\n#   • 384-dim dense vectors, great balance of speed and quality\n#   • Runs locally — no API calls needed for embedding\n#\n# FAISS (Facebook AI Similarity Search)\n#   • In-memory vector index for fast cosine similarity search\n#   • Perfect for datasets of this size (~200-400 chunks)\n\nprint(f\"Loading embedding model: {EMBED_MODEL} ...\")\nembeddings = HuggingFaceEmbeddings(\n    model_name=EMBED_MODEL,\n    model_kwargs={\"device\": \"cpu\"},\n    encode_kwargs={\"normalize_embeddings\": True},  # cosine similarity\n)\nprint(\"✅ Embedding model loaded\")\n\nprint(f\"\\nBuilding FAISS index from {len(chunks)} chunks...\")\nvectorstore = FAISS.from_documents(\n    documents=chunks,\n    embedding=embeddings,\n)\n\nprint(f\"✅ FAISS vector store built\")\nprint(f\"   Total vectors indexed : {vectorstore.index.ntotal}\")\nprint(f\"   Embedding dimensions  : {vectorstore.index.d}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:39.714584Z","iopub.execute_input":"2026-06-24T13:02:39.714858Z","iopub.status.idle":"2026-06-24T13:02:47.907874Z","shell.execute_reply.started":"2026-06-24T13:02:39.714808Z","shell.execute_reply":"2026-06-24T13:02:47.907062Z"}},"outputs":[{"name":"stdout","text":"Loading embedding model: sentence-transformers/all-MiniLM-L6-v2 ...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/103 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"3ecd6327209343629cee0b8c4db0113b"}},"metadata":{}},{"name":"stderr","text":"BertModel LOAD REPORT from: sentence-transformers/all-MiniLM-L6-v2\nKey                     | Status     |  | \n------------------------+------------+--+-\nembeddings.position_ids | UNEXPECTED |  | \n\nNotes:\n- UNEXPECTED\t:can be ignored when loading from different task/architecture; not ok if you expect identical arch.\n","output_type":"stream"},{"name":"stdout","text":"✅ Embedding model loaded\n\nBuilding FAISS index from 112 chunks...\n✅ FAISS vector store built\n   Total vectors indexed : 112\n   Embedding dimensions  : 384\n","output_type":"stream"}],"execution_count":60},{"id":"6c303943-9f75-46e5-84ee-1f3b2c6cb998","cell_type":"markdown","source":"## Cell 8 — MMR Retriever Setup","metadata":{}},{"id":"a6aa4863-de51-4ef0-b498-fe5788044c4e","cell_type":"code","source":"# ── MMR Retriever ───────────────────────────────────────────────────────────\n#\n# MMR = Maximal Marginal Relevance\n# Instead of just top-K most similar chunks (which may repeat the same info),\n# MMR balances:\n#   • Relevance to the query\n#   • Diversity among retrieved chunks\n#\n# fetch_k=20 : retrieve 20 candidates first, then pick best 5 via MMR\n# lambda_mult: 0.6 = slightly prefer relevance over diversity\n\nretriever = vectorstore.as_retriever(\n    search_type=\"mmr\",\n    search_kwargs={\n        \"k\": TOP_K,\n        \"fetch_k\": 20,\n        \"lambda_mult\": MMR_LAMBDA,\n    }\n)\n\nprint(\"✅ MMR Retriever ready\")\nprint(f\"   Strategy   : Maximal Marginal Relevance\")\nprint(f\"   Top-K      : {TOP_K} chunks returned\")\nprint(f\"   Fetch-K    : 20 candidates before MMR selection\")\nprint(f\"   Lambda     : {MMR_LAMBDA} (0=diverse, 1=relevant)\")\n\n# Quick retrieval test\ntest_q   = \"How many earned leaves do employees get per year?\"\ntest_res = retriever.invoke(test_q)\nprint(f\"\\n🔍 Test retrieval for: '{test_q}'\")\nfor i, doc in enumerate(test_res, 1):\n    print(f\"   [{i}] {doc.metadata.get('source','?')} | page {doc.metadata.get('page','?')} | {len(doc.page_content)} chars\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:47.909034Z","iopub.execute_input":"2026-06-24T13:02:47.909323Z","iopub.status.idle":"2026-06-24T13:02:47.938495Z","shell.execute_reply.started":"2026-06-24T13:02:47.909301Z","shell.execute_reply":"2026-06-24T13:02:47.937904Z"}},"outputs":[{"name":"stdout","text":"✅ MMR Retriever ready\n   Strategy   : Maximal Marginal Relevance\n   Top-K      : 5 chunks returned\n   Fetch-K    : 20 candidates before MMR selection\n   Lambda     : 0.6 (0=diverse, 1=relevant)\n\n🔍 Test retrieval for: 'How many earned leaves do employees get per year?'\n   [1] 02_Leave_Policy | page 1 | 728 chars\n   [2] 06_Compensation_and_Benefits_Policy | page 2 | 797 chars\n   [3] 06_Compensation_and_Benefits_Policy | page 1 | 703 chars\n   [4] 02_Leave_Policy | page 1 | 744 chars\n   [5] 01_Employee_Handbook | page 2 | 796 chars\n","output_type":"stream"}],"execution_count":61},{"id":"cf5ac1bc-f35d-4708-b926-a73ab4dd0121","cell_type":"markdown","source":"## Cell 9 — ✅ TODO 4: LCEL RAG Chain","metadata":{}},{"id":"8f7eb1f3-18bd-4ad1-907f-7b5b5ecc9e95","cell_type":"code","source":"# ── TODO 4: Build the LCEL RAG chain ───────────────────────────────────────\n#\n# LCEL (LangChain Expression Language) lets us compose a chain using | pipes.\n#\n# Chain flow:\n#   question ──► retriever ──► format_context ──► prompt ──► LLM ──► answer\n#\n# The system prompt enforces grounding:\n#   • Only answer from retrieved context\n#   • If answer not in context → say so honestly\n\n# ── 1. LLM ──────────────────────────────────────────────────────────────────\nllm = ChatGroq(\n    model=LLM_MODEL,\n    temperature=0,          # deterministic answers for HR policy (no creativity needed)\n    max_tokens=512,\n    api_key=GROQ_API_KEY,\n)\n\n# ── 2. Prompt Template ──────────────────────────────────────────────────────\nRAG_PROMPT_TEMPLATE = \"\"\"\\\nYou are an intelligent HR Help Desk assistant for Zyro Dynamics Pvt. Ltd.\nYour role is to answer employee questions STRICTLY based on the company's\nofficial HR policy documents provided below as context.\n\nRULES:\n1. Answer ONLY from the provided context. Do not use outside knowledge.\n2. Be precise, professional, and concise.\n3. If the answer is not in the context, say:\n   \"I'm sorry, I couldn't find this information in Zyro Dynamics' HR policy documents.\"\n4. Never make up policy numbers, dates, or entitlements.\n5. Cite the source document name when possible.\n\n--- CONTEXT FROM HR POLICY DOCUMENTS ---\n{context}\n--- END OF CONTEXT ---\n\nEmployee Question: {question}\n\nAnswer:\"\"\"\n\nprompt = ChatPromptTemplate.from_template(RAG_PROMPT_TEMPLATE)\n\n# ── 3. Context Formatter ─────────────────────────────────────────────────────\ndef format_docs(docs: list) -> str:\n    \"\"\"Format retrieved chunks into a single context string with source labels.\"\"\"\n    formatted = []\n    for i, doc in enumerate(docs, 1):\n        source = doc.metadata.get(\"source\", \"Unknown\")\n        page   = doc.metadata.get(\"page\", \"?\")\n        formatted.append(\n            f\"[Source {i}: {source} | Page {page}]\\n{doc.page_content.strip()}\"\n        )\n    return \"\\n\\n\".join(formatted)\n\n# ── 4. LCEL Chain ────────────────────────────────────────────────────────────\n#\n# RunnablePassthrough() passes the original question through unchanged.\n# The chain:\n#   {context: retriever(q) → format_docs, question: passthrough}\n#   → prompt → llm → parse string\n\nrag_chain = (\n    {\n        \"context\":  retriever | RunnableLambda(format_docs),\n        \"question\": RunnablePassthrough(),\n    }\n    | prompt\n    | llm\n    | StrOutputParser()\n)\n\nprint(\"✅ LCEL RAG Chain built\")\nprint(\"   Components: Retriever → PromptTemplate → Groq LLM → StrOutputParser\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:47.97381Z","iopub.execute_input":"2026-06-24T13:02:47.974381Z","iopub.status.idle":"2026-06-24T13:02:48.077136Z","shell.execute_reply.started":"2026-06-24T13:02:47.974358Z","shell.execute_reply":"2026-06-24T13:02:48.076534Z"}},"outputs":[{"name":"stdout","text":"✅ LCEL RAG Chain built\n   Components: Retriever → PromptTemplate → Groq LLM → StrOutputParser\n","output_type":"stream"}],"execution_count":62},{"id":"cadd2da6-b2f8-4e6c-8268-2e3b1a7c1c85","cell_type":"markdown","source":"## Cell 10 — ✅ TODO 5: Out-of-Scope Guardrails","metadata":{}},{"id":"2626ca52-3827-49f2-a121-2077e39a8e02","cell_type":"code","source":"# ── TODO 5: Guardrails for out-of-scope questions ───────────────────────────\n#\n# Strategy: Two-layer detection\n#\n# Layer 1 — Fast keyword check:\n#   Catches obvious off-topic questions instantly (no LLM call needed).\n#   Topics clearly outside HR: stock prices, cooking, sports, coding, etc.\n#\n# Layer 2 — LLM semantic relevance check:\n#   For ambiguous questions, ask the LLM to classify relevance to HR.\n#   Only runs if keyword check doesn't flag the question.\n#\n# HR-relevant topics (in scope):\n#   leave, salary, benefits, performance, conduct, wfh, onboarding,\n#   travel reimbursement, harassment, IT policy, probation, separation\n\n# ── HR keywords (broad, to avoid false refusals) ─────────────────────────────\nHR_KEYWORDS = [\n    # Leave & attendance\n    \"leave\", \"vacation\", \"pto\", \"sick\", \"maternity\", \"paternity\",\n    \"casual\", \"earned leave\", \"el\", \"sl\", \"attendance\", \"holiday\",\n    # Compensation\n    \"salary\", \"ctc\", \"pay\", \"bonus\", \"increment\", \"payslip\", \"appraisal\",\n    \"compensation\", \"benefits\", \"insurance\", \"pf\", \"gratuity\", \"allowance\",\n    # Work arrangements\n    \"wfh\", \"work from home\", \"remote\", \"hybrid\", \"office\",\n    # HR processes\n    \"probation\", \"onboarding\", \"offboarding\", \"resignation\", \"notice\",\n    \"separation\", \"full and final\", \"f&f\", \"joining\", \"offer letter\",\n    # Performance\n    \"performance\", \"appraisal\", \"rating\", \"review\", \"pip\", \"goal\", \"kra\",\n    # Conduct & policy\n    \"conduct\", \"ethics\", \"policy\", \"discipline\", \"posh\", \"harassment\",\n    \"complaint\", \"grievance\", \"icc\",\n    # IT & security\n    \"laptop\", \"device\", \"password\", \"data\", \"security\", \"vpn\", \"software\",\n    # Travel\n    \"travel\", \"reimbursement\", \"expense\", \"flight\", \"hotel\", \"per diem\",\n    # Company\n    \"zyro\", \"company\", \"employee\", \"hr\", \"human resource\", \"department\",\n]\n\n# ── Refusal message template ─────────────────────────────────────────────────\nOUT_OF_SCOPE_RESPONSE = (\n    \"I'm sorry, but I can only answer HR-related questions based on \"\n    \"Zyro Dynamics' official policy documents. Your question appears to be \"\n    \"outside the scope of HR policies. Please reach out to the HR team directly \"\n    \"for other queries, or ask me about topics like leave policy, compensation, \"\n    \"work-from-home rules, performance reviews, or employee conduct.\"\n)\n\n# ── LLM-based scope classifier ───────────────────────────────────────────────\nSCOPE_CHECK_PROMPT = ChatPromptTemplate.from_template(\"\"\"\\\nYou are a strict HR policy assistant scope classifier.\nAnswer ONLY with a single word: YES or NO.\n\nIs the following question related to any of these HR topics?\n- Employee leave, attendance, holidays\n- Salary, compensation, benefits, bonuses\n- Work-from-home, remote, hybrid work\n- Onboarding, probation, offboarding, resignation\n- Performance reviews, appraisals, PIPs\n- Code of conduct, ethics, disciplinary actions\n- POSH, harassment, ICC complaints\n- IT policy, data security, device usage\n- Travel and expense reimbursements\n- Zyro Dynamics company overview or culture\n\nQuestion: {question}\n\nAnswer (YES or NO only):\"\"\"\n)\n\nscope_classifier_chain = (\n    SCOPE_CHECK_PROMPT\n    | llm\n    | StrOutputParser()\n)\n\n\ndef is_in_scope(question: str) -> bool:\n    \"\"\"Two-layer check: keyword match first, then LLM classifier if unsure.\"\"\"\n    q_lower = question.lower()\n\n    # Layer 1: Fast keyword check\n    if any(kw in q_lower for kw in HR_KEYWORDS):\n        return True\n\n    # Layer 2: LLM semantic check for ambiguous questions\n    result = scope_classifier_chain.invoke({\"question\": question})\n    return result.strip().upper().startswith(\"YES\")\n\n\ndef ask_hr_bot(question: str) -> dict:\n    \"\"\"\n    Main entry point for the HR chatbot.\n    Returns a dict with 'answer', 'in_scope', and 'sources'.\n    \"\"\"\n    if not is_in_scope(question):\n        return {\n            \"answer\":   OUT_OF_SCOPE_RESPONSE,\n            \"in_scope\": False,\n            \"sources\":  [],\n        }\n\n    # Retrieve source documents for citation display\n    source_docs = retriever.invoke(question)\n    answer      = rag_chain.invoke(question)\n\n    sources = [\n        {\n            \"document\": doc.metadata.get(\"source\", \"Unknown\"),\n            \"page\":     doc.metadata.get(\"page\", \"?\"),\n        }\n        for doc in source_docs\n    ]\n\n    return {\n        \"answer\":   answer,\n        \"in_scope\": True,\n        \"sources\":  sources,\n    }\n\n\nprint(\"✅ Guardrails configured\")\nprint(f\"   Layer 1 : Keyword filter ({len(HR_KEYWORDS)} HR keywords)\")\nprint( \"   Layer 2 : LLM semantic scope classifier\")\nprint( \"   Refusal : Polite, informative out-of-scope message\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:48.077949Z","iopub.execute_input":"2026-06-24T13:02:48.078219Z","iopub.status.idle":"2026-06-24T13:02:48.089728Z","shell.execute_reply.started":"2026-06-24T13:02:48.0782Z","shell.execute_reply":"2026-06-24T13:02:48.088882Z"}},"outputs":[{"name":"stdout","text":"✅ Guardrails configured\n   Layer 1 : Keyword filter (75 HR keywords)\n   Layer 2 : LLM semantic scope classifier\n   Refusal : Polite, informative out-of-scope message\n","output_type":"stream"}],"execution_count":63},{"id":"bfd93b70-ae45-456f-bffe-24e9b0a17197","cell_type":"markdown","source":"## Cell 11 — ✅ TODO 6: Test the Bot","metadata":{}},{"id":"bc2025b1-0fed-4304-803c-f870afe94b80","cell_type":"code","source":"# ── TODO 6: Test with sample questions ─────────────────────────────────────\n\ndef pretty_print_result(question: str, result: dict):\n    print(\"=\" * 70)\n    print(f\"❓ Q: {question}\")\n    print(\"-\" * 70)\n    scope_label = \"✅ IN SCOPE\" if result[\"in_scope\"] else \"🚫 OUT OF SCOPE\"\n    print(f\"   {scope_label}\")\n    print(f\"\\n💬 Answer:\\n{result['answer']}\")\n    if result[\"sources\"]:\n        print(\"\\n📚 Sources:\")\n        seen = set()\n        for s in result[\"sources\"]:\n            key = (s[\"document\"], s[\"page\"])\n            if key not in seen:\n                print(f\"   • {s['document']} | Page {s['page']}\")\n                seen.add(key)\n    print()\n\n\n# ── Sample in-scope questions ────────────────────────────────────────────────\nin_scope_tests = [\n    \"How many earned leaves are employees entitled to per year?\",\n    \"What is the work-from-home policy at Zyro Dynamics?\",\n    \"What is the notice period for resignation?\",\n]\n\n# ── Sample out-of-scope questions ───────────────────────────────────────────\nout_of_scope_tests = [\n    \"What is the best recipe for biryani?\",\n    \"Who won the 2024 FIFA World Cup?\",\n]\n\nall_tests = in_scope_tests + out_of_scope_tests\n\nprint(\"\\n🤖 Testing HR Help Desk Bot...\\n\")\n\nfor q in all_tests:\n    result = ask_hr_bot(q)\n    pretty_print_result(q, result)\n\nprint(\"✅ All test questions answered\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:48.28411Z","iopub.execute_input":"2026-06-24T13:02:48.284385Z","iopub.status.idle":"2026-06-24T13:02:50.597439Z","shell.execute_reply.started":"2026-06-24T13:02:48.284366Z","shell.execute_reply":"2026-06-24T13:02:50.596739Z"}},"outputs":[{"name":"stdout","text":"\n🤖 Testing HR Help Desk Bot...\n\n======================================================================\n❓ Q: How many earned leaves are employees entitled to per year?\n----------------------------------------------------------------------\n   ✅ IN SCOPE\n\n💬 Answer:\nAccording to the 02_Leave_Policy document, employees are entitled to 15 days of Earned Leave upon completion of one year of continuous service, provided they have worked for a minimum of 240 days in that year. Thereafter, Earned Leave accrues at the rate of 1.25 days per month.\n\n📚 Sources:\n   • 02_Leave_Policy | Page 1\n   • 06_Compensation_and_Benefits_Policy | Page 2\n   • 06_Compensation_and_Benefits_Policy | Page 1\n   • 01_Employee_Handbook | Page 2\n\n======================================================================\n❓ Q: What is the work-from-home policy at Zyro Dynamics?\n----------------------------------------------------------------------\n   ✅ IN SCOPE\n\n💬 Answer:\nThe work-from-home policy at Zyro Dynamics is outlined in the document \"Work From Home Policy\" (Doc Code: ZDL-HR-003, Version: V.02, Effective Date: 01 March 2025). According to this policy, employees are allowed to work from a location other than their designated Zyro Dynamics office, with the expectation that all WFH arrangements will be exercised responsibly and that the quality and timeliness of work will not be compromised. (Source: 03_Work_From_Home_Policy)\n\n📚 Sources:\n   • 03_Work_From_Home_Policy | Page 0\n   • 10_Travel_and_Expense_Policy | Page 0\n   • 03_Work_From_Home_Policy | Page 2\n   • 08_Prevention_of_Sexual_Harassment_Policy | Page 1\n   • 02_Leave_Policy | Page 0\n\n======================================================================\n❓ Q: What is the notice period for resignation?\n----------------------------------------------------------------------\n   ✅ IN SCOPE\n\n💬 Answer:\nI'm sorry, I couldn't find this information in Zyro Dynamics' HR policy documents. The notice period for resignation is mentioned as \"applicable to their grade\" in Source 1: 09_Onboarding_and_Separation_Policy, but the specific notice period for each grade is not provided.\n\n📚 Sources:\n   • 09_Onboarding_and_Separation_Policy | Page 1\n   • 02_Leave_Policy | Page 1\n   • 06_Compensation_and_Benefits_Policy | Page 1\n   • 06_Compensation_and_Benefits_Policy | Page 0\n   • 09_Onboarding_and_Separation_Policy | Page 2\n\n======================================================================\n❓ Q: What is the best recipe for biryani?\n----------------------------------------------------------------------\n   🚫 OUT OF SCOPE\n\n💬 Answer:\nI'm sorry, but I can only answer HR-related questions based on Zyro Dynamics' official policy documents. Your question appears to be outside the scope of HR policies. Please reach out to the HR team directly for other queries, or ask me about topics like leave policy, compensation, work-from-home rules, performance reviews, or employee conduct.\n\n======================================================================\n❓ Q: Who won the 2024 FIFA World Cup?\n----------------------------------------------------------------------\n   🚫 OUT OF SCOPE\n\n💬 Answer:\nI'm sorry, but I can only answer HR-related questions based on Zyro Dynamics' official policy documents. Your question appears to be outside the scope of HR policies. Please reach out to the HR team directly for other queries, or ask me about topics like leave policy, compensation, work-from-home rules, performance reviews, or employee conduct.\n\n✅ All test questions answered\n","output_type":"stream"}],"execution_count":65},{"id":"159b0b72-e7a7-4b37-99e1-697426ee16c5","cell_type":"markdown","source":"## Cell 12 — Competition Questions (Q01–Q15)","metadata":{}},{"id":"c8821665-7fe1-4803-96a7-c77a09d4f396","cell_type":"code","source":"# ── 15 Competition Questions ────────────────────────────────────────────────\n#\n# Q01–Q10 : In-scope HR questions   (8 pts each = 80 pts)\n# Q11–Q15 : Out-of-scope questions  (4 pts each = 20 pts — must REFUSE!)\n\ncompetition_questions = [\n    # ── In-scope HR questions ───────────────────────────────────────────────\n    \"What is the probation period for new employees at Zyro Dynamics?\",                          # Q01\n    \"How many earned leaves are employees entitled to per year?\",                                 # Q02\n    \"What is the work-from-home policy for Zyro Dynamics employees?\",                            # Q03\n    \"What are the performance rating categories used in the annual performance review?\",          # Q04\n    \"What is the reimbursement limit for domestic travel at Zyro Dynamics?\",                     # Q05\n    \"What action can be taken against an employee who violates the code of conduct?\",            # Q06\n    \"What is the maternity leave entitlement at Zyro Dynamics?\",                                 # Q07\n    \"How should an employee report a sexual harassment complaint?\",                               # Q08\n    \"What are the IT security responsibilities of Zyro Dynamics employees?\",                     # Q09\n    \"What is the full and final settlement process when an employee resigns?\",                   # Q10\n\n    # ── Out-of-scope questions — bot must refuse these ──────────────────────\n    \"What is the current stock price of Infosys?\",                                               # Q11\n    \"Can you recommend a good Python course for data science?\",                                  # Q12\n    \"What is the weather forecast for Chennai tomorrow?\",                                        # Q13\n    \"Who won the IPL 2024 cricket tournament?\",                                                  # Q14\n    \"How do I make a chocolate cake at home?\",                                                   # Q15\n]\n\nprint(f\"Running {len(competition_questions)} competition questions...\\n\")\n\nanswers = []\nfor i, question in enumerate(competition_questions, 1):\n    qid = f\"Q{i:02d}\"\n    print(f\"⏳ {qid}: {question[:60]}...\")\n    result = ask_hr_bot(question)\n    answers.append({\n        \"question_id\": qid,\n        \"question\":    question,\n        \"answer\":      result[\"answer\"],\n        \"in_scope\":    result[\"in_scope\"],\n    })\n    scope_tag = \"✅\" if result[\"in_scope\"] else \"🚫\"\n    print(f\"   {scope_tag} Done — {len(result['answer'])} chars\")\n\nprint(f\"\\n✅ All {len(answers)} answers generated\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-24T13:02:50.598268Z","iopub.execute_input":"2026-06-24T13:02:50.598657Z","iopub.status.idle":"2026-06-24T13:03:33.338515Z","shell.execute_reply.started":"2026-06-24T13:02:50.598634Z","shell.execute_reply":"2026-06-24T13:03:33.337881Z"}},"outputs":[{"name":"stdout","text":"Running 15 competition questions...\n\n⏳ Q01: What is the probation period for new employee